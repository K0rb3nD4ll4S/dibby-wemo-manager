# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build output ──────────────────────────────────────────────────────────────
dist/
out/
build/
*.blockmap
*.tgz
builder-debug.yml
builder-effective-config.yaml

# ── Electron app user data written at runtime ─────────────────────────────────
apps/desktop/WemoManagerData/

# ── Code signing certificate — NEVER commit private keys ─────────────────────
*.pfx
*.p12
*.key
*.pem

# ── Bundled Node binary (~91 MB; copy from system Node before building) ──────
apps/desktop/resources/node.exe

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── OS artefacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Temporary files ───────────────────────────────────────────────────────────
*.tmp
*.temp
.cache/

# ── Local editor / tooling caches ────────────────────────────────────────────
.claude/

# ── Bundled Node binaries (gitignored; ~70-95 MB each; build CI downloads them) ──
apps/desktop/resources/node-macos
apps/desktop/resources/node-macos-x64
apps/desktop/resources/node-macos-arm64
apps/desktop/resources/node-linux
apps/desktop/resources/node-linux-x64
apps/desktop/resources/node-linux-arm64
